<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="44dp"
        android:paddingBottom="14dp"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#1A73E8"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Upload Expenses"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0D1B4B" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp">

            <!-- Hero Banner -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A73E8">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REIMBURSEMENT PORTAL"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#B3D1FF"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upload Expenses"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Submit your research and travel receipts for institutional review."
                        android:textSize="13sp"
                        android:textColor="#B3D1FF" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ─────────────────────────────────────── -->
            <!-- Trip Name -->
            <!-- ─────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRIP NAME"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#5A7FA8"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_history"
                        app:tint="#1A73E8"
                        android:layout_marginEnd="10dp" />

                    <EditText
                        android:id="@+id/etTripName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@null"
                        android:hint="e.g. Delhi Conference 2025"
                        android:textColorHint="#B0B8CC"
                        android:textColor="#0D1B4B"
                        android:textSize="14sp"
                        android:inputType="textCapWords"
                        android:imeOptions="actionNext"
                        android:maxLines="1" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Duration of Trip -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DURATION OF TRIP"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#5A7FA8"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="From Date"
                            android:textSize="11sp"
                            android:textColor="#8A93B2"
                            android:layout_marginBottom="6dp" />
                        <TextView
                            android:id="@+id/tvFromDate"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:text="dd-mm-yyyy"
                            android:textColor="#B0B8CC"
                            android:textSize="13sp"
                            android:background="@drawable/bg_date_field"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#B0B8CC"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="To Date"
                            android:textSize="11sp"
                            android:textColor="#8A93B2"
                            android:layout_marginBottom="6dp" />
                        <TextView
                            android:id="@+id/tvToDate"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:text="dd-mm-yyyy"
                            android:textColor="#B0B8CC"
                            android:textSize="13sp"
                            android:background="@drawable/bg_date_field"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Receipt Evidence -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECEIPT EVIDENCE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#5A7FA8"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:scrollbars="none"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Take Photo button -->
                    <LinearLayout
                        android:id="@+id/btnTakeReceiptPhoto"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_date_field"
                        android:layout_marginEnd="10dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_add_box"
                            app:tint="#1A73E8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Take Photo"
                            android:textColor="#1A73E8"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Receipt thumbnails added dynamically -->
                    <LinearLayout
                        android:id="@+id/layoutReceiptPhotos"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Claim Amount -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLAIM AMOUNT"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#5A7FA8"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1A73E8"
                        android:layout_marginEnd="8dp" />
                    <EditText
                        android:id="@+id/etClaimAmount"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@null"
                        android:hint="0.00"
                        android:textColorHint="#B0B8CC"
                        android:textColor="#0D1B4B"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:inputType="numberDecimal" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Detailed Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DETAILED DESCRIPTION"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#5A7FA8"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <EditText
                    android:id="@+id/etExpenseDescription"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@null"
                    android:gravity="top|start"
                    android:hint="Explain the business purpose of this expense..."
                    android:textColorHint="#B0B8CC"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:padding="16dp"
                    android:inputType="textMultiLine"
                    android:scrollbars="vertical" />
            </androidx.cardview.widget.CardView>

            <!-- Submit Button -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnSubmitExpense"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                app:cardCornerRadius="27dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#1A73E8"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_visibility"
                        app:tint="#FFFFFF"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Submit Expense"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav — 5 items -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:weightSum="5"
        android:background="#FFFFFF"
        android:elevation="16dp">

        <LinearLayout android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_home" app:tint="#AAAAAA" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textSize="9sp" android:textColor="#AAAAAA"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navPost"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_add_box" app:tint="#AAAAAA" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Post" android:textSize="9sp" android:textColor="#AAAAAA"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navHistory"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_history" app:tint="#AAAAAA" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="History" android:textSize="9sp" android:textColor="#AAAAAA"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navExpenses"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_expenses"
                app:tint="#AAAAAA" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expenses"
                android:textSize="9sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_person" app:tint="#AAAAAA" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profile" android:textSize="9sp" android:textColor="#AAAAAA"
                android:layout_marginTop="3dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>