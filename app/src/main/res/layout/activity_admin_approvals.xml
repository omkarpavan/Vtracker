<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══════════════════  MAIN CONTENT  ═══════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F5F7FA">

        <!-- ── Header ─────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="40dp"
            android:paddingBottom="14dp"
            android:background="#FFFFFF">

            <ImageView
                android:id="@+id/ivMenu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#1A73E8"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Approvals"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#0D1B4B" />

            <TextView
                android:id="@+id/tvApprovedBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_badge"
                android:backgroundTint="#34A853"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="0 approved"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Stats row (each card is clickable = filter) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:weightSum="3"
            android:background="#FFFFFF"
            android:elevation="2dp">

            <!-- Total -->
            <LinearLayout
                android:id="@+id/layoutStatTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tvStatTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#0D1B4B" />
                <TextView
                    android:id="@+id/tvStatTotalLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Posts"
                    android:textSize="10sp"
                    android:textColor="#8A93B2"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="1dp" android:layout_height="40dp"
                android:layout_gravity="center_vertical" android:background="#E0E0E0" />

            <!-- Approved -->
            <LinearLayout
                android:id="@+id/layoutStatApproved"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tvStatApproved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#34A853" />
                <TextView
                    android:id="@+id/tvStatApprovedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Approved"
                    android:textSize="10sp"
                    android:textColor="#8A93B2"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="1dp" android:layout_height="40dp"
                android:layout_gravity="center_vertical" android:background="#E0E0E0" />

            <!-- Pending -->
            <LinearLayout
                android:id="@+id/layoutStatPending"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tvStatPending"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FB8C00" />
                <TextView
                    android:id="@+id/tvStatPendingLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="10sp"
                    android:textColor="#8A93B2"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Tab Bar ─────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:elevation="1dp">

            <LinearLayout
                android:id="@+id/tabVisits"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tvTabVisits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Visits"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A73E8" />
                <View
                    android:id="@+id/indicatorVisits"
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="4dp"
                    android:background="#1A73E8" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabExpenses"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tvTabExpenses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expenses"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#8A93B2" />
                <View
                    android:id="@+id/indicatorExpenses"
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="4dp"
                    android:background="@android:color/transparent" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Scrollable cards ────────────────────────────── -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp">

                <FrameLayout
                    android:id="@+id/loadingOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:visibility="gone">
                    <ProgressBar
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="#1A73E8" />
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/layoutEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#EEEEEE" />
                    <TextView
                        android:id="@+id/tvEmptyMsg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No Posts Found"
                        android:textColor="#8A93B2"
                        android:textSize="14sp"
                        android:layout_marginTop="12dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="#E53935"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/containerCards"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </ScrollView>

        <!-- ── Bottom Nav ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:orientation="horizontal"
            android:weightSum="5"
            android:background="#FFFFFF"
            android:elevation="16dp">

            <LinearLayout android:id="@+id/navDashboard"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:clickable="true" android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_home" app:tint="#AAAAAA" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Dashboard" android:textSize="8sp" android:textColor="#AAAAAA"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/navSearch"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:clickable="true" android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_visibility" app:tint="#AAAAAA" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Search" android:textSize="8sp" android:textColor="#AAAAAA"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/navAddUsers"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:clickable="true" android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_person" app:tint="#AAAAAA" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Add Users" android:textSize="8sp" android:textColor="#AAAAAA"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/navApprovals"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:clickable="true" android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_check_circle" app:tint="#1A73E8" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Approvals" android:textSize="8sp" android:textColor="#1A73E8"
                    android:textStyle="bold" android:layout_marginTop="3dp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/navProfile"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:clickable="true" android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_person" app:tint="#AAAAAA" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Profile" android:textSize="8sp" android:textColor="#AAAAAA"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════════════  SIDE DRAWER  ═══════════════════ -->
    <LinearLayout
        android:id="@+id/sideDrawer"
        android:layout_width="290dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <LinearLayout
            android:id="@+id/drawerHeaderProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="52dp"
            android:background="@drawable/bg_drawer_header">

            <androidx.cardview.widget.CardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="2dp">
                <TextView
                    android:id="@+id/tvDrawerAvatarLetter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="A"
                    android:textColor="#1A73E8"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvDrawerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Admin Name"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDrawerRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Administrator"
                android:textColor="#B3D1FF"
                android:textSize="12sp" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout android:id="@+id/drawerDashboard"
                    style="@style/DrawerItemStyle">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:src="@drawable/ic_home" app:tint="#1A73E8" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="16dp" android:text="Dashboard" />
                </LinearLayout>

                <LinearLayout android:id="@+id/drawerSearch"
                    style="@style/DrawerItemStyle">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:src="@drawable/ic_visibility" app:tint="#1A73E8" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="16dp" android:text="Search" />
                </LinearLayout>

                <LinearLayout android:id="@+id/drawerApprovals"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_drawer_item_active">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:src="@drawable/ic_check_circle" app:tint="#1A73E8" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="16dp" android:text="Approvals"
                        android:textColor="#1A73E8" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:id="@+id/drawerLogout"
                    style="@style/DrawerItemStyle">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:src="@drawable/ic_logout" app:tint="#E53935" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="16dp" android:text="Logout"
                        android:textColor="#E53935" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>